+
+def _tvm_relax_compile(
+    gm: fx.GraphModule,
+    example_inputs: list[torch.Tensor],
+    options: MappingProxyType[str, Any],
+) -> Callable[..., Any]:
+    from tvm.relax.frontend.torch import relax_dynamo  # type: ignore[import]
