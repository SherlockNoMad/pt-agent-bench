+            tensor2 = torch.randn(4, 4, device=device, requires_grad=True)
+            value = torch.tensor(0.5, device=device)
+            return x, tensor1, tensor2, value
+
+        x1, t1e, t2e, v1 = make_inputs()
+        fn(x1, t1e, t2e, v1).backward()
