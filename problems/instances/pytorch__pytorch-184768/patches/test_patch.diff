+        class Repro(torch.nn.Module):
+            def forward(self, arg0, arg1, arg2):
+                vals = torch.ops.aten._foreach_add.Scalar([arg0, arg1, arg2], 1)
+                torch.ops.aten.copy_.default(arg0, vals[0])
